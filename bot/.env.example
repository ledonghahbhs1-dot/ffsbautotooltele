# ── Telegram ──────────────────────────────────────────────────────
# Lấy token từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Website mục tiêu ───────────────────────────────────────────────
# URL website cần tự động tạo tài khoản (không có dấu / ở cuối)
BASE_URL=https://your-target-website.com

# ── Thông tin cá nhân ──────────────────────────────────────────────
FULL_NAME=Ho Va Ten Day Du
STK=1234567890
BANK_NAME=Vietcombank
WITHDRAW_PASS=123456

# ── Tùy chọn: Giới hạn người dùng ────────────────────────────────
# Danh sách Telegram user ID được phép dùng bot (phân cách bằng dấu phẩy)
# Để trống = cho phép tất cả mọi người
ALLOWED_USERS=
