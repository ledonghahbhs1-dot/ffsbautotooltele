# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Website mục tiêu ───────────────────────────────────────────────
BASE_URL=https://fly88h.com

# ── Bảo mật ────────────────────────────────────────────────────────
WITHDRAW_PASS=123456

# ── Giải Captcha — chọn 1 trong 3 phương án ───────────────────────

# Phương án 1 (KHUYẾN NGHỊ): 2captcha.com — chuyên dụng, không bao giờ từ chối
# Đăng ký tại https://2captcha.com → nạp $1-2 là đủ dùng lâu dài
# TWOCAPTCHA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_CAPTCHA_PROVIDER=2captcha

# Phương án 2: OpenAI GPT-4o Vision — có thể từ chối nếu nhận ra là captcha
# OPENAI_API_KEY=sk-...
# AI_CAPTCHA_PROVIDER=openai

# Phương án 3: Google Gemini — ít từ chối hơn OpenAI
# GOOGLE_API_KEY=AIza...
# AI_CAPTCHA_PROVIDER=gemini

# ── Tùy chọn: Giới hạn người dùng ────────────────────────────────
# Danh sách Telegram user ID (phân cách dấu phẩy). Để trống = mở cho tất cả
ALLOWED_USERS=
