# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Website mục tiêu ───────────────────────────────────────────────
BASE_URL=https://your-target-website.com

# ── Bảo mật ────────────────────────────────────────────────────────
WITHDRAW_PASS=123456

# ── AI Captcha Solver ──────────────────────────────────────────────
# Chọn 1 trong 2 provider (openai hoặc gemini)
AI_CAPTCHA_PROVIDER=openai

# Nếu dùng OpenAI (GPT-4o):
OPENAI_API_KEY=sk-...

# Nếu dùng Google Gemini:
# AI_CAPTCHA_PROVIDER=gemini
# GOOGLE_API_KEY=...

# ── Tùy chọn: Giới hạn người dùng ────────────────────────────────
# Danh sách Telegram user ID (phân cách dấu phẩy). Để trống = mở cho tất cả
ALLOWED_USERS=
